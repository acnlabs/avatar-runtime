AVATAR_PROVIDER=heygen
PORT=3721

# ── HeyGen provider ──────────────────────────────────────────────────────────
HEYGEN_API_KEY=
HEYGEN_BASE_URL=https://api.heygen.com
HEYGEN_AVATAR_ID=default
HEYGEN_QUALITY=medium
HEYGEN_TASK_TYPE=chat
HEYGEN_TASK_MODE=sync
HEYGEN_TIMEOUT_MS=20000
# Set true to require HEYGEN_API_KEY and disable mock fallback.
HEYGEN_STRICT=false

# ── Live2D provider (AVATAR_PROVIDER=live2d) ─────────────────────────────────
# Start bridge first: npm run dev:live2d-cubism-bridge
LIVE2D_ENDPOINT=http://127.0.0.1:3755
LIVE2D_MODEL3_URL=
LIVE2D_MODEL_ID=default
LIVE2D_TIMEOUT_MS=10000
# Set true to require LIVE2D_ENDPOINT and disable mock fallback.
LIVE2D_STRICT=false

# ── KusaPics provider (AVATAR_PROVIDER=kusapics) ─────────────────────────────
KUSAPICS_API_KEY=
KUSAPICS_BASE_URL=
# Set true to require KUSAPICS_API_KEY and disable mock fallback.
KUSAPICS_STRICT=false
