# Live2D model assets — downloaded or user-provided, not source
# Placeholder files (default.model.json / default.model3.json) are tracked via explicit git add
# Infrastructure slot dirs (expressions/ motions/ textures/) stay tracked — model dirs are ignored
assets/live2d/slot/*/
!assets/live2d/slot/expressions/
!assets/live2d/slot/motions/
!assets/live2d/slot/textures/
assets/live2d/licenses/ATTRIBUTION.sample.md

# VRM model assets — user-provided, not source
assets/vrm/slot/*.vrm
assets/vrm/slot/*.glb
